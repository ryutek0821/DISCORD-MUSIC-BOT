# === Required ===
DISCORD_TOKEN=your_discord_bot_token_here

# === niconico login (required for niconico playback) ===
# Netscape-format cookie file; created and refreshed automatically.
COOKIE_FILE=cookies.txt
NICO_EMAIL=your_niconico_email
NICO_PASSWORD=your_niconico_password

# === Optional ===
# chromedriver path for the Selenium cookie fallback.
CHROMEDRIVER_PATH=/usr/bin/chromedriver
# niconico cookie cache lifetime (seconds).
COOKIE_TTL=3600
# Persistent guild session storage (must be outside the deployed repository).
STATE_DIR=~/.local/share/inmermusic
# Disconnect from an idle voice channel after this many seconds.
IDLE_TIMEOUT=180
# Give up on a single audio download after this many seconds.
DOWNLOAD_TIMEOUT=120
# Directory for downloaded audio files (use a real-disk path, not tmpfs).
DOWNLOAD_DIR=/var/tmp/inmermusic
# Reject tracks longer than this many seconds.
MAX_TRACK_DURATION=1800
# Maximum queued tracks per guild.
MAX_QUEUE_SIZE=100
# Maximum tracks accepted from one playlist command.
MAX_PLAYLIST_SIZE=50
# Guildごとに保存できる名前付きプレイリスト数
MAX_PLAYLISTS_PER_GUILD=25
# Maximum size of the one-track-per-guild prefetch cache.
PREFETCH_MAX_BYTES=268435456
# If set, also write rotating logs here (journald already captures stdout).
# LOG_FILE=bot.log
# Route YouTube traffic through a residential-IP HTTP proxy to dodge datacenter
# bot detection. Leave unset when the bot already runs on a residential IP.
# YT_PROXY=http://100.114.153.17:8888
# Optional failover list. When set, this takes precedence over YT_PROXY.
# YT_PROXIES=http://user:pass@primary:8888,http://user:pass@secondary:8888
